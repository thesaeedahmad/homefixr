# HomeFixr API — environment variables (PLACEHOLDERS ONLY)
# Copy this file to ".env" and replace placeholders with real values when available.
# NEVER commit the real ".env" file (it is gitignored).

# --- Server ---
PORT=4000
NODE_ENV=development
WEB_ORIGIN=http://localhost:3000

# --- Database: Supabase PostgreSQL (placeholder connection string) ---
# Used by Prisma. Replace USER/PASSWORD/HOST with real Supabase values later.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/homefixr?schema=public

# --- Used in later iterations (kept here for documentation; not read yet) ---
# JWT secret (Iteration 1: Authentication)
JWT_SECRET=replace-with-a-long-random-secret
# Cloudinary media storage (Iteration 2/3)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
